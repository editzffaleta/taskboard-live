# =============================================================================
# Backend NestJS (monorepo npm workspaces) — multi-stage p/ Dokploy
# Copie para: apps/backend/Dockerfile  ·  Build context: RAIZ do monorepo
# TODO por projeto: caminho do schema Prisma e nome do main.js se divergirem.
# =============================================================================

# ---- 1) Dependências completas (dev incluído, para buildar) ----------------
FROM node:22-alpine AS builder
WORKDIR /app

# Manifests primeiro (cache de camada do npm ci)
COPY package.json package-lock.json turbo.json ./
COPY apps/backend/package.json apps/backend/
COPY packages ./packages
COPY modules ./modules
RUN npm ci

# Código e build
COPY . .
RUN npm exec -w apps/backend -- prisma generate \
 && npm run build --workspace apps/backend

# ---- 2) Dependências de produção + Prisma Client gerado --------------------
FROM node:22-alpine AS prod-deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/backend/package.json apps/backend/
COPY packages ./packages
COPY modules ./modules
RUN npm ci --omit=dev
# O client Prisma precisa existir no node_modules de produção:
COPY apps/backend/prisma apps/backend/prisma
RUN npm exec -w apps/backend -- prisma generate

# ---- 3) Runner --------------------------------------------------------------
FROM node:22-alpine AS runner
ENV NODE_ENV=production
WORKDIR /app

COPY --from=prod-deps --chown=node:node /app/node_modules ./node_modules
COPY --from=prod-deps --chown=node:node /app/apps/backend/node_modules ./apps/backend/node_modules
COPY --from=builder   --chown=node:node /app/apps/backend/dist ./apps/backend/dist
COPY --from=builder   --chown=node:node /app/apps/backend/prisma ./apps/backend/prisma
COPY --from=builder   --chown=node:node /app/apps/backend/package.json ./apps/backend/package.json
COPY --from=builder   --chown=node:node /app/package.json ./package.json

USER node
EXPOSE 4000

# Dokploy: healthcheck saudável é pré-requisito da rota Traefik (GET /health → 200)
HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD wget -qO- http://127.0.0.1:4000/health || exit 1

# Migrations idempotentes ANTES de subir (nunca `migrate dev` em produção).
# O Nest deve escutar em 0.0.0.0 (app.listen(4000, '0.0.0.0')).
CMD ["sh", "-c", "npm exec -w apps/backend -- prisma migrate deploy && node apps/backend/dist/main.js"]
