# /etc/caddy/Caddyfile
# Automatic HTTPS (Let's Encrypt) + reverse proxy.
# Point the domain's DNS A record at the VPS IP BEFORE reloading Caddy, or the
# certificate issuance will fail.
#
# Reload after editing:  sudo systemctl reload caddy

example.com {
    encode zstd gzip

    # API -> NestJS. This PRESERVES the /api prefix, matching a Nest app that
    # uses app.setGlobalPrefix('api'). If your API has NO prefix, use
    # `handle_path /api/*` instead (it strips /api before proxying).
    handle /api/* {
        reverse_proxy 127.0.0.1:4000
    }

    # Everything else -> Next.js
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}

# Optional: redirect the www host to the apex
# www.example.com {
#     redir https://example.com{uri}
# }
