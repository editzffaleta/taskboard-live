# Modelo de variaveis de ambiente — COPIE para .env e preencha.
# NUNCA coloque valores reais aqui (este arquivo e versionado).
# (O config-project-fullstack tambem gera .env.example por app; este e o da raiz.)

# Ambiente
NODE_ENV=development

# Banco de dados (Prisma / PostgreSQL)
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO?schema=public"

# Autenticacao (JWT)
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"
JWT_EXPIRES_IN="1d"

# Portas
BACKEND_PORT=4000
FRONTEND_PORT=3000
