#!/usr/bin/env bash
# Valida que a mensagem segue Conventional Commits. Sem dependências.
set -euo pipefail

msg_file="$1"
first_line="$(head -n1 "$msg_file")"

# Permite commits de merge/revert/fixup gerados pelo git
if printf '%s' "$first_line" | grep -qE '^(Merge|Revert|fixup!|squash!)'; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'

if ! printf '%s' "$first_line" | grep -qE "$pattern"; then
  echo "✖ Mensagem de commit fora do padrão Conventional Commits."
  echo "  Recebido: $first_line"
  echo "  Formato:  <tipo>(<escopo opcional>): <assunto>"
  echo "  Tipos:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "  Exemplo:  feat(auth): adiciona logout com limpeza de sessão"
  exit 1
fi
