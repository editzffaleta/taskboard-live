#!/usr/bin/env bash
# Barra commit de segredos. Usa gitleaks (staged) se instalado; senao, regex (sem deps).
set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$staged" ] && exit 0

fail=0

# 1) Arquivos .env (exceto .env.example)
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    .env.example) ;;
    .env|.env.*) echo "✖ Não comite '$f' (segredo). Use .env.example."; fail=1 ;;
  esac
done <<< "$staged"

# 2) Conteúdo: gitleaks (preferido) ou regex (fallback sem dependências)
if command -v gitleaks >/dev/null 2>&1 && [ -f scripts/ci/gitleaks-scan.sh ]; then
  if ! bash scripts/ci/gitleaks-scan.sh staged; then
    echo "✖ gitleaks encontrou possível segredo no que está em stage."
    fail=1
  fi
else
  secret_re='(BEGIN [A-Z ]*PRIVATE KEY|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{20,})'
  if git diff --cached -U0 | grep -nE "$secret_re" >/dev/null 2>&1; then
    echo "✖ Possível segredo detectado no diff (chave privada / token)."
    echo "  (Sem gitleaks instalado — checagem por regex. Instale o gitleaks para cobertura melhor.)"
    fail=1
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "  (Falso positivo? Ajuste o .gitleaksignore, ou o hook em .githooks/pre-commit.)"
  exit 1
fi
