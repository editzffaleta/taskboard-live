# --- gitignore.secrets kit ---

# === Kit de segredos (hardening do .gitignore) ===
# Chaves e certificados
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
# Dumps/backups que podem conter dados sensiveis
*.dump
*.sql.gz
# Uploads / storage local
/uploads/
/storage/
**/uploads/
**/storage/
# Relatorio do gitleaks, se gerado
gitleaks-report.*
