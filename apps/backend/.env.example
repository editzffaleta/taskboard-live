DB_HOST="localhost"
DB_PORT="6284"
DB_USER="taskboard_taskboard_live"
DB_PASSWORD="docker"
DB_NAME="taskboard_taskboard_live_db"
DATABASE_URL="postgresql://taskboard_taskboard_live:docker@localhost:6284/taskboard_taskboard_live_db?schema=public"
PORT="4000"
JWT_SECRET=""
JWT_EXPIRES_IN="1d"

# Hardening HTTP (change 012)
# Origem unica aceita pelo CORS (HTTP e gateway Socket.IO). Obrigatoria quando NODE_ENV=production.
CORS_ORIGIN=http://localhost:3000
# Rate limit global (por IP)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# Rate limit estrito para /auth/register e /auth/login (por IP)
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=5

# Base do frontend para montar o link de convite (change 026)
FRONTEND_URL=http://localhost:3000
