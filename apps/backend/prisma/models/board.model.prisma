model Board {
  id         String    @id @default(uuid())
  name       String
  ownerId    String
  color      String    @default("blue")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  archivedAt DateTime?

  owner       User          @relation("BoardOwner", fields: [ownerId], references: [id])
  members     BoardMember[]
  lists       List[]
  activities  Activity[]
  labels      Label[]
  invitations Invitation[]

  @@map("boards")
}

model BoardMember {
  id        String    @id @default(uuid())
  boardId   String
  userId    String
  role      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@map("board_members")
}

model List {
  id         String    @id @default(uuid())
  boardId    String
  title      String
  position   Int
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@map("lists")
}

model Card {
  id          String    @id @default(uuid())
  listId      String
  title       String
  description String?
  position    Int
  dueDate     DateTime?
  cover       String?
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  list      List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels    CardLabel[]
  checklist ChecklistItem[]
  assignees CardAssignee[]
  comments  Comment[]

  @@index([listId])
  @@map("cards")
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId    String
  text      String
  done      Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("checklist_items")
}

model CardAssignee {
  id        String   @id @default(uuid())
  cardId    String
  userId    String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@map("card_assignees")
}

model Comment {
  id        String   @id @default(uuid())
  cardId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@map("comments")
}

model Label {
  id        String   @id @default(uuid())
  boardId   String
  name      String
  color     String
  createdAt DateTime @default(now())

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
  @@map("labels")
}

model CardLabel {
  id        String   @id @default(uuid())
  cardId    String
  labelId   String
  createdAt DateTime @default(now())

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
  @@map("card_labels")
}

model Activity {
  id        String   @id @default(uuid())
  boardId   String
  actorId   String
  type      String
  data      Json
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@map("activities")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  data      Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model Invitation {
  id          String   @id @default(uuid())
  boardId     String
  email       String
  token       String   @unique
  role        String   @default("member")
  status      String   @default("pending")
  invitedById String
  createdAt   DateTime @default(now())

  board     Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy User  @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([boardId, email])
  @@map("invitations")
}
