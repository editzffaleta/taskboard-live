model Board {
  id        String    @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner      User          @relation("BoardOwner", fields: [ownerId], references: [id])
  members    BoardMember[]
  lists      List[]
  activities Activity[]
  labels     Label[]

  @@map("boards")
}

model BoardMember {
  id        String    @id @default(uuid())
  boardId   String
  userId    String
  role      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@map("board_members")
}

model List {
  id        String   @id @default(uuid())
  boardId   String
  title     String
  position  Int
  createdAt DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@map("lists")
}

model Card {
  id          String    @id @default(uuid())
  listId      String
  title       String
  description String?
  position    Int
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  list      List             @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels    CardLabel[]
  checklist ChecklistItem[]
  assignees CardAssignee[]
  comments  Comment[]

  @@index([listId])
  @@map("cards")
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId    String
  text      String
  done      Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("checklist_items")
}

model CardAssignee {
  id        String   @id @default(uuid())
  cardId    String
  userId    String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@map("card_assignees")
}

model Comment {
  id        String   @id @default(uuid())
  cardId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([cardId, createdAt])
  @@map("comments")
}

model Label {
  id        String   @id @default(uuid())
  boardId   String
  name      String
  color     String
  createdAt DateTime @default(now())

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
  @@map("labels")
}

model CardLabel {
  id        String   @id @default(uuid())
  cardId    String
  labelId   String
  createdAt DateTime @default(now())

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
  @@map("card_labels")
}

model Activity {
  id        String   @id @default(uuid())
  boardId   String
  actorId   String
  type      String
  data      Json
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id])

  @@index([boardId, createdAt])
  @@map("activities")
}
